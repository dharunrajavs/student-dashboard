# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/academic_intelligence_db
# For SQLite (development): sqlite:///academic_intelligence.db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Email Configuration (Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@academicai.com

# File Upload Configuration
MAX_CONTENT_LENGTH=10485760
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,xls,xlsx,csv

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/1
RATELIMIT_DEFAULT=100 per hour

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ML Model Paths
GPA_MODEL_PATH=ml_models/gpa_predictor.pkl
SCHOLARSHIP_MODEL_PATH=ml_models/scholarship_classifier.pkl
CAREER_MODEL_PATH=ml_models/career_recommender.pkl
RISK_MODEL_PATH=ml_models/risk_scorer.pkl

# Report Configuration
REPORTS_FOLDER=reports
LOGO_PATH=static/logo.png

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Admin Configuration
ADMIN_EMAIL=admin@academicai.com
ADMIN_PASSWORD=Admin@123

# Performance Thresholds
LOW_ATTENDANCE_THRESHOLD=75
LOW_GPA_THRESHOLD=6.0
HIGH_RISK_THRESHOLD=70

# Notification Settings
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_NOTIFICATIONS=False

# Cache TTL (seconds)
CACHE_TTL=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
